{
	"name": "create-openzosma",
	"version": "0.1.0",
	"description": "Interactive setup CLI for OpenZosma -- self-hosted AI agent platform",
	"type": "module",
	"license": "Apache-2.0",
	"bin": {
		"create-openzosma": "./dist/index.js"
	},
