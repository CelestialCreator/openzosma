# ── Database ──────────────────────────────────────────────────────────────────
# Used by gateway (individual vars) and web app (connection string)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openzosma
DB_USER=openzosma
DB_PASS=openzosma
DB_POOL_SIZE=20
DATABASE_URL=postgresql://openzosma:openzosma@localhost:5432/openzosma

# ── Valkey / Redis ────────────────────────────────────────────────────────────
VALKEY_URL=redis://localhost:6379

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://openzosma:openzosma@localhost:5672

# ── Web App (apps/web) ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000

# better-auth reads this automatically for session signing
BETTER_AUTH_SECRET=change-me-in-production

# AES-256 encryption key for integration credentials stored in DB.
# In dev, a fallback is used automatically. In production, set a 64-char hex
# string or a passphrase (will be derived via scrypt).
ENCRYPTION_KEY=

# Google OAuth (optional — remove socialProviders block in auth.ts if unused)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0

# ── Orchestrator gRPC ─────────────────────────────────────────────────────────
ORCHESTRATOR_GRPC_PORT=50051
ORCHESTRATOR_GRPC_HOST=0.0.0.0

# ── Sandbox ───────────────────────────────────────────────────────────────────
SANDBOX_POOL_SIZE=2
SANDBOX_GRPC_PORT=50052

# ── LLM Provider Keys (at least one required) ────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Local / OpenAI-Compatible Model (optional) ──────────────────────────────
# Set OPENZOSMA_LOCAL_MODEL_URL to use a local LLM server (llama.cpp, Ollama,
# vLLM, LM Studio, etc.). When set, this takes priority over all cloud providers.
OPENZOSMA_LOCAL_MODEL_URL=http://192.168.1.100:30080/v1
OPENZOSMA_LOCAL_MODEL_ID=Qwen3.5-35B-A3B-Q8_0.gguf
OPENZOSMA_LOCAL_MODEL_NAME=
OPENZOSMA_LOCAL_MODEL_API_KEY=dummy
OPENZOSMA_LOCAL_MODEL_CONTEXT_WINDOW=131072
OPENZOSMA_LOCAL_MODEL_MAX_TOKENS=32768
